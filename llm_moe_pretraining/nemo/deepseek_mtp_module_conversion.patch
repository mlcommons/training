@@ -53,22 +53,26 @@ def provider_bridge(self, hf_pretrained: PreTrainedCausalLM) -> DeepSeekV3ModelP
         if hasattr(hf_config, "aux_loss_alpha"):
             configs["moe_aux_loss_coeff"] = hf_config.aux_loss_alpha
 
